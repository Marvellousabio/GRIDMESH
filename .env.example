# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL="your_supabase_url"

# SUPABASE_ANON_KEY: The anonymous public key for your Supabase project.
SUPABASE_ANON_KEY="your_supabase_anon_key"

# VITE_API_BASE_URL: The base URL for the backend API (used by frontend)
VITE_API_BASE_URL="http://localhost:5000"

# FLUTTERWAVE_PUBLIC_KEY: Public key for Flutterwave API
FLUTTERWAVE_PUBLIC_KEY="your_flutterwave_public_key"

# FLUTTERWAVE_SECRET_KEY: Secret key for Flutterwave API
FLUTTERWAVE_SECRET_KEY="your_flutterwave_secret_key"

# FLUTTERWAVE_WEBHOOK_SECRET: Webhook secret for verifying Flutterwave webhooks
FLUTTERWAVE_WEBHOOK_SECRET="your_webhook_secret"

# MOCK_PAYMENTS: Set to 'true' to use mock payments for testing (hackathon mode)
MOCK_PAYMENTS="false"

# DEMO_MODE: Set to 'true' to enable automatic demo data generation
DEMO_MODE="false"
